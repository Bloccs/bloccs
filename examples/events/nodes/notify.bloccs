[node]
id      = "notify"
version = "0.1.0"
kind    = "sink"

[doc]
intent = "Notify a downstream webhook that a known event was processed."
owner  = "@example"

[ports.in]
event = { schema = "EnrichedEvent@1" }

[ports.out]
notified = { schema = "Notified@1" }

[effects]
http = { allow = ["hooks.local"], methods = ["POST"] }

[contract]
pure_core    = "Events.Nodes.Notify.transform/2"
effect_shell = "Events.Nodes.Notify.execute/2"
