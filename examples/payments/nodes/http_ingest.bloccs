[node]
id      = "http_ingest"
version = "0.1.0"
kind    = "source"

[doc]
intent = "Accept an HTTP charge request and forward it as a typed ChargeRequest."
owner  = "@payments"

[ports.in]
http_request = { schema = "HttpRequest@1", buffer = 1000 }

[ports.out]
charge_request = { schema = "ChargeRequest@1" }

[effects]

[contract]
pure_core    = "Payments.Nodes.HttpIngest.transform/2"
effect_shell = "Payments.Nodes.HttpIngest.execute/2"
