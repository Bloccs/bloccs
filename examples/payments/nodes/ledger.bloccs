[node]
id      = "ledger"
version = "0.1.0"
kind    = "sink"

[doc]
intent = "Append a 'charge_completed' event to the ledger."

[ports.in]
event = { schema = "ChargeCompleted@1" }

[ports.out]
committed = { schema = "LedgerEvent@1" }

[effects]
db = { allow = ["ledger:insert"] }

[contract]
pure_core    = "Payments.Nodes.Ledger.transform/2"
effect_shell = "Payments.Nodes.Ledger.execute/2"
