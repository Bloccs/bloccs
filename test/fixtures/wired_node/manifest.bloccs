[node]
id      = "wired_demo"
version = "0.0.1"
kind    = "transform"

# As of v0.2 every field below is wired into the runtime, so this manifest
# must compile WITHOUT any "parsed-but-unwired" warning. This fixture is the
# regression guard for that (see Bloccs.NodeMacroWiredFieldsTest).

[ports.in]
in_a = { schema = "X@1", buffer = 50 }

[ports.out]
out_a = { schema = "X@1" }

[effects]

[contract]
pure_core    = "Bloccs.Test.WiredNode.transform/2"
effect_shell = "Bloccs.Test.WiredNode.execute/2"
retry        = { strategy = "linear", max = 2, on = ["timeout"] }
timeout_ms   = 1000
idempotency  = { key = "request_id" }

[observability]
metrics = ["duration_ms"]
traces  = "auto"
